{
	"info": {
		"_postman_id": "medical-agent-tests",
		"name": "Medical Agent API - Testes Completos",
		"description": "Collection completa de testes para o agente autônomo de agendamento médico.\n\nPasso 1: Execute o Health Check.\nPasso 2: Execute os testes na ordem.\nPasso 3: Copie o sessionId retornado nos testes de conversa para manter o contexto.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8080",
			"type": "string"
		},
		{
			"key": "session_id",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "00 - Health Check",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/api/health",
					"host": ["{{base_url}}"],
					"path": ["api", "health"]
				},
				"description": "Verifica se a aplicação está rodando corretamente."
			},
			"response": [],
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status code is 200', function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"pm.test('Service is UP', function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.status).to.eql('UP');",
							"    pm.expect(jsonData.service).to.eql('medical-agent');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			]
		},
		{
			"name": "01 - Criar Sessão",
			"request": {
				"method": "POST",
				"header": [],
				"url": {
					"raw": "{{base_url}}/api/session",
					"host": ["{{base_url}}"],
					"path": ["api", "session"]
				},
				"description": "Cria uma nova sessão de conversa e retorna um sessionId UUID."
			},
			"response": [],
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status code is 200', function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"pm.test('Session ID is returned', function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.sessionId).to.not.be.empty;",
							"    pm.collectionVariables.set('session_id', jsonData.sessionId);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			]
		},
		{
			"name": "02 - Saudação (sem sessão)",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"userMessage\": \"Olá, quero agendar uma consulta\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/chat",
					"host": ["{{base_url}}"],
					"path": ["api", "chat"]
				},
				"description": "Primeira mensagem sem sessionId. A API cria a sessão automaticamente."
			},
			"response": [],
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status code is 200', function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"pm.test('Session ID and reply returned', function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.sessionId).to.not.be.empty;",
							"    pm.expect(jsonData.replyText).to.not.be.empty;",
							"    pm.collectionVariables.set('session_id', jsonData.sessionId);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			]
		},
