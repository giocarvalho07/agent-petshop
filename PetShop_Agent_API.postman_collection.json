{
	"info": {
		"_postman_id": "petshop-agent-collection",
		"name": "PetShop Agent API",
		"description": "Collection de testes para o PetShop Agent — Agente Autônomo de IA para agendamento de serviços no PetShop PetCare.\n\nEndpoints disponíveis:\n- GET  /api/health\n- POST /api/session\n- POST /api/chat\n\nAtendentes cadastrados:\n- Ana (Banho & Tosa)\n- Carlos (Consultas)\n- Roberto (Pronto Socorro)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080",
			"type": "string"
		},
		{
			"key": "sessionId",
			"value": "",
			"type": "string",
			"description": "Preenchido automaticamente após criar sessão ou enviar primeira mensagem"
		}
	],
	"item": [
		{
			"name": "🔹 Teste 0 — Health Check",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/health",
					"host": ["{{baseUrl}}"],
					"path": ["api", "health"]
				},
				"description": "Verifica se a aplicação está no ar.\n\nResultado esperado:\n{ \"status\": \"UP\", \"service\": \"petshop-agent\" }"
			},
			"response": [],
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status 200 OK\", () => pm.response.to.have.status(200));",
							"pm.test(\"Service é petshop-agent\", () => {",
							"    const body = pm.response.json();",
							"    pm.expect(body.status).to.eql('UP');",
							"    pm.expect(body.service).to.eql('petshop-agent');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			]
		},
		{
			"name": "🔹 Teste 1 — Criar Sessão",
			"request": {
				"method": "POST",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/session",
					"host": ["{{baseUrl}}"],
					"path": ["api", "session"]
				},
				"description": "Cria uma nova sessão de conversa e retorna um sessionId UUID.\n\nResultado esperado:\n{ \"sessionId\": \"xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx\" }"
			},
			"response": [],
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status 200 OK\", () => pm.response.to.have.status(200));",
							"pm.test(\"sessionId retornado\", () => {",
							"    const body = pm.response.json();",
							"    pm.expect(body.sessionId).to.be.a('string').and.not.empty;",
							"    pm.collectionVariables.set('sessionId', body.sessionId);",
							"    console.log('sessionId salvo:', body.sessionId);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			]
		},
		{
			"name": "🔹 Teste 2 — Primeira Mensagem (Saudação)",
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Content-Type", "value": "application/json" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"userMessage\": \"Olá, quero agendar um serviço para meu pet\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/chat",
					"host": ["{{baseUrl}}"],
					"path": ["api", "chat"]
				},
				"description": "Inicia a conversa sem sessionId — será criado automaticamente.\n\nResultado esperado: agente cumprimenta e pergunta qual serviço ou atendente desejado."
			},
			"response": [],
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status 200 OK\", () => pm.response.to.have.status(200));",
							"pm.test(\"sessionId gerado automaticamente\", () => {",
							"    const body = pm.response.json();",
							"    pm.expect(body.sessionId).to.be.a('string').and.not.empty;",
							"    pm.expect(body.replyText).to.be.a('string').and.not.empty;",
							"    pm.collectionVariables.set('sessionId', body.sessionId);",
							"    console.log('sessionId:', body.sessionId);",
							"    console.log('Agente:', body.replyText);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			]
		},
		{
			"name": "🔹 Teste 3 — Buscar Atendente por Nome (Ana — Existente)",
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Content-Type", "value": "application/json" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"sessionId\": \"{{sessionId}}\",\n  \"userMessage\": \"Quero agendar com a Ana\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/chat",
					"host": ["{{baseUrl}}"],
					"path": ["api", "chat"]
				},
				"description": "Continua a conversa informando um atendente cadastrado.\n\nResultado esperado: agente reconhece Ana (Banho & Tosa) e pergunta data e horário."
			},
			"response": [],
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status 200 OK\", () => pm.response.to.have.status(200));",
							"pm.test(\"Resposta não vazia\", () => {",
							"    const body = pm.response.json();",
							"    pm.expect(body.replyText).to.be.a('string').and.not.empty;",
							"    console.log('Agente:', body.replyText);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			]
		},
		{
			"name": "🔹 Teste 4 — Buscar Atendente por Nome (Maria — Inexistente)",
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Content-Type", "value": "application/json" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"userMessage\": \"Quero agendamento com a Maria\"\n}"
