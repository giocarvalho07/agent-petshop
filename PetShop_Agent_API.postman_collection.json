				},
				"description": "Passo 1 do fluxo completo — inicia a conversa.\n\nResultado esperado: agente pergunta qual serviço ou atendente."
			},
			"response": [],
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status 200 OK\", () => pm.response.to.have.status(200));",
