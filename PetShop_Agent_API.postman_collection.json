							"pm.collectionVariables.set('sessionId', body.sessionId);",
							"console.log('[Passo 1] sessionId:', body.sessionId);",
							"console.log('[Passo 1] Agente:', body.replyText);"
						],
						"type": "text/javascript"
					}
				}
			]
		},
